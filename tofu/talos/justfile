set shell := ["zsh", "-lc"]
set dotenv-path := "../../setup.env"
set dotenv-load
set dotenv-required := false

[private]
default:
    @just --list

# Generate terraform.tfvars from setup.env
configure:
    #!/usr/bin/env bash
    set -euo pipefail
    bridge="${VM_BRIDGE_INTERFACE:-br0}"
    vip="${TALOS_VIP:-192.168.1.99}"
    {
        printf 'libvirt_uri = "qemu+ssh://%s@%s/system"\n\n' "$HYPERVISOR_USER" "$HYPERVISOR_HOST"
        printf 'vm_bridge_interface = "%s"\n\n' "$bridge"
        printf 'image = {\n  version = "v1.12.0"\n}\n\n'
        printf 'cluster = {\n'
        printf '  name               = "talos"\n'
        printf '  vip                = "%s"\n' "$vip"
        printf '  kubernetes_version = "v1.32.0"\n'
        printf '}\n\n'
        printf 'nodes = {\n'
        printf '  "talos-00" = {}\n'
        printf '  "talos-01" = {}\n'
        printf '  "talos-02" = {}\n'
        printf '}\n'
    } > terraform.tfvars
    echo "Created terraform.tfvars (3 nodes via DHCP, vip ${vip})"

# Initialise OpenTofu providers and modules
init:
    tofu init

# Preview changes without applying
plan:
    tofu plan

# Bootstrap the cluster (or apply config drift)
apply:
    tofu apply

# Roll OS upgrades sequentially (bump image.version in terraform.tfvars first)
upgrade:
    tofu apply -parallelism=1

# Destroy all managed resources
destroy:
    tofu destroy

# Run talosctl against the cluster using the generated talosconfig
talosctl *args:
    @talosctl --talosconfig output/talosconfig {{ args }}

# Run kubectl against the cluster using the generated kubeconfig
kubectl *args:
    #!/usr/bin/env bash
    if kubectl --kubeconfig output/kubeconfig {{ args }}; then
        exit 0
    fi
    rc=$?
    vip="${TALOS_VIP:-}"
    printf '\n--- kubectl failed; diagnostics ---\n' >&2
    if [[ -n "$vip" ]]; then
        printf '  VIP %s ICMP:     ' "$vip" >&2
        timeout 2 ping -c1 "$vip" &>/dev/null && printf 'reachable\n' >&2 || printf 'unreachable\n' >&2
        printf '  VIP %s TCP 6443: ' "$vip" >&2
        nc -4 -zw3 "$vip" 6443 2>/dev/null && printf 'open\n' >&2 || printf 'closed/filtered\n' >&2
    fi
    printf '  Talos node health (direct IPs):\n' >&2
    talosctl --talosconfig output/talosconfig get members -o table 2>&1 | sed 's/^/    /' >&2 || true
    if [[ -n "$vip" ]]; then
        printf '  VIP holder:\n' >&2
        talosctl --talosconfig output/talosconfig get addresses 2>&1 \
            | grep -E "(NODE|$(printf '%s' "$vip" | sed 's/\./\\./g'))" \
            | sed 's/^/    /' >&2 || true
    fi
    exit $rc

# Open a serial console to a Talos node (Ctrl+] to exit)
console node:
    @ssh -t "${HYPERVISOR_USER}@${HYPERVISOR_HOST}" "virsh console talos-{{ node }}"
