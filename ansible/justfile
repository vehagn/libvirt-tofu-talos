set shell := ["zsh", "-lc"]
set dotenv-path := "../setup.env"
set dotenv-load
set dotenv-required := false

ansible_inventory := env_var_or_default("ANSIBLE_INVENTORY", "inventory.local.yaml")

[private]
default:
    @just --list

# Generate inventory.local.yaml from setup.env (HYPERVISOR_HOST, HYPERVISOR_USER)
configure:
    envsubst '${HYPERVISOR_HOST} ${HYPERVISOR_USER}' < inventory.yaml > inventory.local.yaml
    @echo "Created inventory.local.yaml"

# Bootstrap the hypervisor with Ansible (pass extra args e.g. --check for dry run)
bootstrap *args:
    ansible-playbook -i {{ansible_inventory}} site.yaml {{args}}
