set shell := ["zsh", "-lc"]
set dotenv-path := "../../setup.env"
set dotenv-load
set dotenv-required := false

[private]
default:
    @just --list

# Generate terraform.tfvars from setup.env; SSH keys fetched from agent or ~/.ssh/*.pub
configure:
    #!/usr/bin/env bash
    set -euo pipefail
    ssh_keys=$(ssh-add -L 2>/dev/null || true)
    if [[ -z "$ssh_keys" ]]; then
        for f in ~/.ssh/id_ed25519.pub ~/.ssh/id_rsa.pub ~/.ssh/id_ecdsa.pub; do
            [[ -f "$f" ]] && ssh_keys+="$(cat "$f")"$'\n'
        done
        ssh_keys="${ssh_keys%$'\n'}"
    fi
    if [[ -z "$ssh_keys" ]]; then
        echo "Error: no SSH keys found — load keys with ssh-add, or place a public key in ~/.ssh/*.pub" >&2
        exit 1
    fi
    keys_hcl=""
    while IFS= read -r key; do
        [[ -n "$key" ]] && keys_hcl+="  \"${key}\","$'\n'
    done <<< "$ssh_keys"
    bridge="${VM_BRIDGE_INTERFACE:-br0}"
    {
        printf 'libvirt_uri = "qemu+ssh://%s@%s/system"\n\n' "$HYPERVISOR_USER" "$HYPERVISOR_HOST"
        printf 'ssh_authorized_keys = [\n%s]\n\n' "$keys_hcl"
        if [[ "$bridge" == "null" ]]; then
            printf 'vm_bridge_interface = null  # private NAT network\n\n'
        else
            printf 'vm_bridge_interface = "%s"\n\n' "$bridge"
        fi
        if [[ -n "${VM_USER_PASSWORD:-}" ]]; then
            printf 'vm_user_password = "%s"\n\n' "$VM_USER_PASSWORD"
        fi
        printf '# Optional overrides (defaults shown)\n'
        printf '# vm_name         = "ubuntu"\n'
        printf '# vm_memory_mb    = 2048\n'
        printf '# vm_vcpu_count   = 2\n'
        printf '# vm_disk_size_gb = 20\n'
    } > terraform.tfvars
    echo "Created terraform.tfvars ($(echo "$ssh_keys" | grep -c .) SSH key(s))"

# Initialize OpenTofu providers and modules
init:
    tofu init

# Preview changes without applying
plan:
    tofu plan

# Apply the configuration
apply:
    tofu apply

# Destroy all managed resources
destroy:
    tofu destroy

# SSH into the VM
ssh:
    #!/usr/bin/env bash
    set -euo pipefail
    ip=$(tofu output -raw vm_ip 2>/dev/null)
    if [[ -z "$ip" ]]; then
        echo "Error: vm_ip output is empty — run 'just apply' first" >&2
        exit 1
    fi
    exec ssh "ubuntu@$ip"

# Open a serial console to the VM via the hypervisor (exit with Ctrl+])
console:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! tofu output vm_name >/dev/null 2>&1; then
        echo "Error: VM not found in state — run 'just apply' first" >&2
        exit 1
    fi
    vm=$(tofu output -raw vm_name)
    exec ssh -t "${HYPERVISOR_USER}@${HYPERVISOR_HOST}" "virsh console $vm"
